#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="${SHORTCUT_INDEX_HOME:-$HOME/Developer/shortcut-index}"
LOG_FILE="${SHORTCUT_INDEX_LOG:-${TMPDIR:-/tmp}/shortcut-index-dev.log}"
LABEL="dev.shortcutindex.dev"
PLIST_FILE="$HOME/Library/LaunchAgents/$LABEL.plist"
SERVICE_TARGET="gui/$(id -u)/$LABEL"

export PATH="$HOME/.nvm/versions/node/v22.18.0/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

if [[ ! -d "$PROJECT_DIR" ]]; then
  printf 'Shortcut Index project not found: %s\n' "$PROJECT_DIR" >&2
  exit 1
fi

if ! command -v npm >/dev/null 2>&1; then
  printf 'npm was not found on PATH. Install Node.js or update PATH in %s.\n' "$0" >&2
  exit 1
fi

write_launch_agent() {
  mkdir -p "$(dirname "$PLIST_FILE")" "$(dirname "$LOG_FILE")"
  cat >"$PLIST_FILE" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>$PROJECT_DIR/bin/shortcut-index</string>
    <string>--foreground</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>$PROJECT_DIR</string>
  <key>StandardOutPath</key>
  <string>$LOG_FILE</string>
  <key>StandardErrorPath</key>
  <string>$LOG_FILE</string>
</dict>
</plist>
PLIST
}

is_loaded() {
  launchctl print "$SERVICE_TARGET" >/dev/null 2>&1
}

case "${1:-}" in
  --foreground)
    exec npm --prefix "$PROJECT_DIR" run dev
    ;;
  --background|-b)
    write_launch_agent
    if is_loaded; then
      launchctl kickstart -k "$SERVICE_TARGET" >/dev/null 2>&1 || true
      printf 'Shortcut Index is already loaded; restarted the dev app.\n'
      printf 'Log: %s\n' "$LOG_FILE"
      exit 0
    fi

    launchctl bootstrap "gui/$(id -u)" "$PLIST_FILE"
    printf 'Shortcut Index starting in the background.\n'
    printf 'Log: %s\n' "$LOG_FILE"
    ;;
  --status)
    if is_loaded; then
      printf 'Shortcut Index LaunchAgent is loaded.\n'
      printf 'Log: %s\n' "$LOG_FILE"
    else
      printf 'Shortcut Index LaunchAgent is not loaded.\n'
      exit 1
    fi
    ;;
  --stop)
    if is_loaded; then
      launchctl bootout "gui/$(id -u)" "$PLIST_FILE"
      printf 'Shortcut Index stopped.\n'
    else
      printf 'Shortcut Index LaunchAgent is not loaded.\n'
    fi
    ;;
  --help|-h)
    printf 'Usage: shortcut-index [--background|--foreground|--status|--stop]\n'
    printf '\n'
    printf 'Starts the Shortcut Index Electron dev app from any directory.\n'
    ;;
  "")
    exec npm --prefix "$PROJECT_DIR" run dev
    ;;
  *)
    printf 'Unknown option: %s\n' "$1" >&2
    printf 'Usage: shortcut-index [--background|--foreground|--status|--stop]\n' >&2
    exit 2
    ;;
esac
